# Iterative
def factorial_iter(n):
    fact = 1
    for i in range(1, n+1):
        fact *= i
    return fact

# Recursive
def factorial_rec(n):
    if n == 0 or n == 1:
        return 1
    return n * factorial_rec(n-1)

n = 5

print("Iterative:", factorial_iter(n))
print("Recursive:", factorial_rec(n))
